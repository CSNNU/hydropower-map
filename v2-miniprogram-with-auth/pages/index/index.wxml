<view class="container">
  <!-- Header -->
  <view class="header">
    <text class="logo">⚡</text>
    <view>
      <text class="title">全国小水电站地图查询</text>
      <text class="subtitle">{{loading ? '正在加载数据...' : ('显示附近的水电站 (已加载: ' + loadedCount + ')' )}}</text>
    </view>
  </view>

  <!-- Loading overlay -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载电站数据...</text>
    <text class="loading-hint">首次加载可能需要几秒钟</text>
  </view>

  <!-- Status bar -->
  <view class="status-bar">
    <button class="btn btn-primary" bindtap="locateUser">📍 获取我的位置</button>
    <button class="btn btn-secondary" bindtap="resetMap">🔄 重置地图</button>
    <view class="status">
      <view class="dot {{locActive ? '' : 'off'}}"></view>
      <text>{{locText}}</text>
    </view>
    <view class="status">
      <text>附近: {{nearbyCount}} / 共: {{totalCount}}</text>
    </view>
  </view>

  <!-- Filter bar -->
  <view class="filter-bar">
    <input class="search-input" placeholder="输入电站名称..." value="{{searchInput}}" bindinput="onSearchInput" />
    <button class="btn-search" bindtap="doSearch">搜索</button>
    <button class="btn-clear" bindtap="clearFilter">清除</button>
  </view>

  <!-- Advanced filter toggle -->
  <view class="filter-toggle" bindtap="toggleFilter">
    <text>{{showFilter ? '收起筛选' : '高级筛选'}} {{showFilter ? '▲' : '▼'}}</text>
  </view>

  <!-- Filter panel (expandable) -->
  <view class="filter-panel" wx:if="{{showFilter}}">
    <picker mode="selector" range="{{provinceList}}" value="{{selectedProvince ? provinceList.indexOf(selectedProvince) : ''}}" bindchange="onProvinceChange">
      <view class="picker-item">省份: {{selectedProvince || '全部'}}</view>
    </picker>
    <picker mode="selector" range="{{cityList}}" value="{{selectedCity ? cityList.indexOf(selectedCity) : ''}}" bindchange="onCityChange">
      <view class="picker-item">市: {{selectedCity || '全部'}}</view>
    </picker>
    <picker mode="selector" range="{{countyList}}" value="{{selectedCounty ? countyList.indexOf(selectedCounty) : ''}}" bindchange="onCountyChange">
      <view class="picker-item">县: {{selectedCounty || '全部'}}</view>
    </picker>

    <view class="radius-row">
      <text>搜索半径:</text>
      <input type="number" value="{{radius}}" bindinput="onRadiusInput" style="width:80px;" />
      <text>公里</text>
      <button class="btn-apply" bindtap="applyRadius">刷新</button>
    </view>
  </view>

  <!-- Map -->
  <map id="stationMap"
       class="map"
       latitude="{{userLat || 35.0}}"
       longitude="{{userLng || 105.0}}"
       scale="12"
       markers="{{markers}}"
       show-location="{{true}}"
       enable-zoom="{{true}}"
       bindmarkertap="onMarkerTap">
  </map>

  <!-- Detail panel overlay -->
  <view class="detail-overlay" wx:if="{{showDetail}}" bindtap="closeDetail">
    <view class="detail-panel" catchtap="noop">
      <view class="panel-header">
        <text class="station-name">{{detailStation.name}}</text>
        <text class="close-btn" bindtap="closeDetail">✕</text>
      </view>

      <view class="info-grid">
        <view class="info-item">
          <text class="label">省份</text>
          <text class="value">{{detailStation.provinceStr}}</text>
        </view>
        <view class="info-item">
          <text class="label">城市</text>
          <text class="value">{{detailStation.cityStr}}</text>
        </view>
        <view class="info-item">
          <text class="label">区县</text>
          <text class="value">{{detailStation.countyStr}}</text>
        </view>
        <view class="info-item">
          <text class="label">装机容量</text>
          <text class="value">{{detailStation.capacityStr}}</text>
        </view>
        <view class="info-item">
          <text class="label">开发方式</text>
          <text class="value">{{detailStation.typeStr}}</text>
        </view>
        <view class="info-item">
          <text class="label">电站属性</text>
          <text class="value">{{detailStation.attrStr}}</text>
        </view>
        <view class="info-item">
          <text class="label">距离</text>
          <text class="value">{{detailStation.distance}} km (距厂房)</text>
        </view>
      </view>

      <!-- Coordinates -->
      <view class="coord-section">
        <text class="section-title">坐标信息</text>
        <view class="coord-row" wx:if="{{detailStation.dam_lat}}">
          <text class="coord-label">🏔 坝址</text>
          <text class="coord-value">{{detailStation.damLatStr}}, {{detailStation.damLngStr}}</text>
          <text class="coord-nav" bindtap="navigateToDam" data-lat="{{detailStation.dam_lat}}" data-lng="{{detailStation.dam_lng}}">导航</text>
        </view>
        <view class="coord-row">
          <text class="coord-label">🏭 厂房</text>
          <text class="coord-value">{{detailStation.factoryLatStr}}, {{detailStation.factoryLngStr}}</text>
          <text class="coord-nav" bindtap="navigateToFactory" data-lat="{{detailStation.factory_lat}}" data-lng="{{detailStation.factory_lng}}">导航</text>
        </view>
      </view>

      <!-- Contact info -->
      <view class="contact-section">
        <text class="section-title">联系信息</text>
        <view class="contact-row">
          <text>👤 联系人: {{detailStation.contactStr}}</text>
        </view>
        <view class="contact-row phone-row" wx:if="{{detailStation.phone && detailStation.phone !== '未知'}}" bindtap="makeCall" data-phone="{{detailStation.phone}}">
          <text class="phone-link">📞 {{detailStation.phoneStr}} (点击拨打)</text>
        </view>
      </view>

      <!-- Action buttons -->
      <view class="action-buttons">
        <button class="btn-navigate" bindtap="navigateToStation">🚚 导航前往</button>
      </view>
    </view>
  </view>

  <!-- Legend -->
  <view class="legend">
    <text class="legend-title">图例</text>
    <view class="legend-item">
      <view class="legend-icon station"></view>
      <text>附近水电站</text>
    </view>
    <view class="legend-item">
      <view class="legend-icon user"></view>
      <text>我的位置</text>
    </view>
  </view>
</view>
