.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #1a5276 0%, #2980b9 100%);
  padding: 40rpx;
}
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}
.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}
.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}
.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}
.form-area {
  width: 100%;
  max-width: 600rpx;
}
.input-group {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}
.phone-input {
  height: 100rpx;
  font-size: 32rpx;
}
.login-btn {
  background: #ffffff;
  color: #1a5276;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  height: 100rpx;
  line-height: 100rpx;
}
.login-btn[disabled] {
  background: rgba(255, 255, 255, 0.5);
  color: rgba(26, 82, 118, 0.5);
}
.error-msg {
  margin-top: 30rpx;
  padding: 20rpx;
  background: rgba(231, 76, 60, 0.9);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
}
.footer {
  margin-top: 80rpx;
}
.hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
